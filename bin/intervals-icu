#!/bin/sh
# intervals-icu CLI wrapper
# Requires Bun: https://bun.sh

if ! command -v bun >/dev/null 2>&1; then
  echo "❌ Bun is required but not found."
  echo "   Install: curl -fsSL https://bun.sh/install | bash"
  exit 1
fi

# Resolve real script path (following symlinks)
SCRIPT_SOURCE="${BASH_SOURCE[0]:-$0}"
while [ -L "$SCRIPT_SOURCE" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ $SCRIPT_SOURCE != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"

# Search for intervals-icu-cli module in standard locations
for MODULE_PATH in \
  "$SCRIPT_DIR/../lib/node_modules/intervals-icu-cli" \
  "$SCRIPT_DIR/.."
do
  # Resolve absolute path (in case of symlink)
  RESOLVED_PATH="$(cd "$MODULE_PATH" 2>/dev/null && pwd)"
  if [ -n "$RESOLVED_PATH" ] && [ -f "$RESOLVED_PATH/dist/src/index.js" ]; then
    exec bun "$RESOLVED_PATH/dist/src/index.js" "$@"
  fi
done

echo "❌ Could not find intervals-icu-cli module"
echo "   Expected: $SCRIPT_DIR/../lib/node_modules/intervals-icu-cli/dist/src/index.js"
exit 1
